  </section>

  <style>
    .projects-page { padding: 3rem 0; }

    .projects-header { text-align: center; margin-bottom: 2.5rem; }

    .page-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      margin: 0 0 0.4rem;
    }

    .page-subtitle {
      color: var(--muted);
      font-size: 1rem;
      margin: 0;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      column-gap: 0.75rem;
      row-gap: 1.25rem;
    }

    @media (max-width: 1280px) {
      .cards-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 1024px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .cards-grid { grid-template-columns: 1fr; }
    }

    /* Override global Layout.astro card padding/gap — must be explicit */
    .card {
      padding: 0 !important;
      gap: 0 !important;
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
    }

    .card:hover {
      border-color: #4f9cf950;
      box-shadow: 0 6px 24px #4f9cf910;
      transform: translateY(-2px);
    }

    /* Image: full bleed, no margin */
    .card-image-wrapper {
      width: 100%;
      height: 140px;
      margin: 0;
      padding: 0;
      background: var(--surface2);
      overflow: hidden;
      flex-shrink: 0;
      display: block;
    }

    .card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      margin: 0;
      padding: 0;
      transition: transform 0.3s ease;
    }

    .card:hover .card-image { transform: scale(1.03); }

    .card-image-placeholder {
      height: 140px;
      background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    }

    /* Content */
    .card-content {
      flex: 1;
      padding: 0.7rem 0.75rem 0.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    /* Tags: first 3 on row 1, remainder on row 2 */
    .tags {
      display: flex !important;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 0.2rem;
    }

    .tag {
      font-size: 0.7rem;
      font-family: 'Fira Code', monospace;
      padding: 0.18rem 0.45rem;
      border-radius: 4px;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }

    /* Zero-size flex break injected after 3rd tag in Python */
    .tag-break {
      flex-basis: 100%;
      width: 0;
      height: 0;
    }

    /* Title: tight spacing above and below */
    .card-title {
      margin: 0.15rem 0 0.1rem;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.25;
    }

    .card-desc {
      margin: 0;
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.55;
    }

    /* Actions: buttons stacked vertically */
    .card-actions {
      padding: 0.4rem 0.75rem 0.6rem;
      margin-top: auto !important;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .card-link-btn {
      display: block;
      text-align: center;
      text-decoration: none;
      box-sizing: border-box;
      background: none;
      border: 1px solid var(--accent);
      color: var(--accent);
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s, color 0.2s;
      flex: 1;
    }

    .card-link-btn:hover {
      background: var(--accent);
      color: #080810;
    }

  </style>
</Layout>
