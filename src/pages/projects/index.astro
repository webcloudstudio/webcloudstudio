---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Selected Projects — Ed Barlow">
  <section class="projects-page">
    <div class="section-inner">
      <div class="projects-header">
        <h1 class="page-title">Selected Projects</h1>
        
      </div>
      <div class="cards-grid">
        <!-- CARD: Ed Barlows Stored Procedure Library -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="images/EdBarlowsStoredProcs.webp" alt="Ed Barlows Stored Procedure Library" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--neutral">Freeware</span>
            <span class="tag tag--neutral">Stored Procedures</span>
            <span class="tag tag--ops">Sybase</span>
            <span class="tag-break"></span>
            <span class="tag tag--ops">Sql Server</span>
            </div>

            <h3 class="card-title">Ed Barlows Stored Procedure Library</h3>

            <p class="card-desc">Widely Used Shareware Stored Procedure Library For SQL Server and Sybase Servers</p>
          </div>

          <div class="card-actions">
            <a href="/project-docs/EdBarlowsStoredProcs/" target="_blank" rel="noopener" class="card-link-btn">Project Documentation ↗</a>
            
          </div>
        </article>

        <!-- CARD: GAME — Generic Agent Management Environment -->
        <article class="card">
          <div class="card-image-wrapper card-image-placeholder"></div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--neutral">dashboard</span>
            <span class="tag tag--neutral">tool</span>
            <span class="tag tag--neutral">platform</span>
            </div>

            <h3 class="card-title">GAME — Generic Agent Management Environment</h3>

            <p class="card-desc">Personal workflow management system for ~14 projects across software, books, and tools. Runs as a local Flask web app with GitHub Pages publishing.</p>
          </div>

          <div class="card-actions">
            <a href="/project-docs/GAME/" target="_blank" rel="noopener" class="card-link-btn">Project Documentation ↗</a>
            
          </div>
        </article>

        <!-- CARD: Herpes Hearts -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="images/HerpesHearts.webp" alt="Herpes Hearts" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--py">Django</span>
            <span class="tag tag--ops">Docker</span>
            <span class="tag tag--ops">Railway</span>
            </div>

            <h3 class="card-title">Herpes Hearts</h3>

            <p class="card-desc">A full-featured community dating platform built for the HSV+ community. Features OAuth-only authentication (Google), custom profiles, messaging, likes, blocking, and profile search.</p>
          </div>

          <div class="card-actions">
            
            
          </div>
        </article>

        <!-- CARD: Process-Based Database Administration -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="images/ProcessBasedDataEngineering.webp" alt="Process-Based Database Administration" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--py">Best Practices</span>
            <span class="tag tag--neutral">Data Engineering</span>
            </div>

            <h3 class="card-title">Process-Based Database Administration</h3>

            <p class="card-desc">A practical guide to modern best practices for enterprise data and database systems management. Covers agile workflows, monitoring, security, disaster recovery, and database development at scale.</p>
          </div>

          <div class="card-actions">
            
            
          </div>
        </article>

        <!-- CARD: Conquer -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="images/conquer_2026.webp" alt="Conquer" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--db">C++</span>
            <span class="tag tag--neutral">Multi-Player Game</span>
            </div>

            <h3 class="card-title">Conquer</h3>

            <p class="card-desc">Conquer is a multi player C game published in the 80s and Early 90s</p>
          </div>

          <div class="card-actions">
            
            
          </div>
        </article>

        <!-- CARD: GEM - The Generic Enterprise Manager -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="images/gem.webp" alt="GEM - The Generic Enterprise Manager" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--db">Perl</span>
            <span class="tag tag--neutral">Enterprise Administration</span>
            </div>

            <h3 class="card-title">GEM - The Generic Enterprise Manager</h3>

            <p class="card-desc">Full featured system management utility competitive with service now</p>
          </div>

          <div class="card-actions">
            <a href="/project-docs/gem/" target="_blank" rel="noopener" class="card-link-btn">Project Documentation ↗</a>
            
          </div>
        </article>
      </div>
    </div>
  </section>

  <style>
    .projects-page { padding: 3rem 0; }

    .projects-header { text-align: center; margin-bottom: 2.5rem; }

    .page-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      margin: 0 0 0.4rem;
    }

    .page-subtitle {
      color: var(--muted);
      font-size: 1rem;
      margin: 0;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      column-gap: 1.5rem;
      row-gap: 1.5rem;
    }

    @media (max-width: 1024px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .cards-grid { grid-template-columns: 1fr; }
    }

    /* Override global Layout.astro card padding/gap — must be explicit */
    .card {
      padding: 0 !important;
      gap: 0 !important;
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
    }

    .card:hover {
      border-color: #4f9cf950;
      box-shadow: 0 6px 24px #4f9cf910;
      transform: translateY(-2px);
    }

    /* Image: full bleed, no margin */
    .card-image-wrapper {
      width: 100%;
      height: 140px;
      margin: 0;
      padding: 0;
      background: var(--surface2);
      overflow: hidden;
      flex-shrink: 0;
      display: block;
    }

    .card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      margin: 0;
      padding: 0;
      transition: transform 0.3s ease;
    }

    .card:hover .card-image { transform: scale(1.03); }

    .card-image-placeholder {
      height: 140px;
      background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    }

    /* Content */
    .card-content {
      flex: 1;
      padding: 0.7rem 1rem 0.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    /* Tags: first 3 on row 1, remainder on row 2 */
    .tags {
      display: flex !important;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 0.2rem;
    }

    .tag {
      font-size: 0.7rem;
      font-family: 'Fira Code', monospace;
      padding: 0.18rem 0.45rem;
      border-radius: 4px;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }

    /* Zero-size flex break injected after 3rd tag in Python */
    .tag-break {
      flex-basis: 100%;
      width: 0;
      height: 0;
    }

    /* Title: tight spacing above and below */
    .card-title {
      margin: 0.15rem 0 0.1rem;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.25;
    }

    .card-desc {
      margin: 0;
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.55;
    }

    /* Actions: docs button above view button */
    .card-actions {
      padding: 0.4rem 1rem 0.6rem;
      margin-top: auto !important;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .card-link-btn {
      display: block;
      text-align: center;
      text-decoration: none;
      box-sizing: border-box;
      background: none;
      border: 1px solid var(--accent);
      color: var(--accent);
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s, color 0.2s;
      width: 100%;
    }

    .card-link-btn:hover {
      background: var(--accent);
      color: #080810;
    }

  </style>
</Layout>
