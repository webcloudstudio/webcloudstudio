---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Agile AI — Ed Barlow">
  <div class="frame-container">
    <iframe
      src={`${base}project-docs/GAME/index.html`}
      title="Agile AI"
      class="frame-iframe"
    ></iframe>
  </div>
  <style>
    .frame-container {
      height: calc(100vh - 68px);
      overflow: hidden;
    }
    .frame-iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
  </style>
</Layout>
