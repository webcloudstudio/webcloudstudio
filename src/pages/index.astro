---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Web Cloud Studio — Ed Barlow">
  <section class="hero">
    <div class="hero-inner">
      <h1><span class="name">Ed Barlow</span></h1>
      <p class="hero-desc">Superb Software engineer, database architect, and published author. Building thoughtful systems for complex problems.</p>
      <div class="hero-cta">
        <a href={`${base}/projects/`} class="btn-primary">View Projects</a>
      </div>
    </div>
    <div class="hero-grid"></div>
  </section>
</Layout>
