---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="AI Process — Ed Barlow">
  <div class="frame-container">
    <iframe
      src={`${base}/project-docs/Specifications/white-paper.html`}
      title="AI Process"
      class="frame-iframe"
    ></iframe>
  </div>
  <style>
    .frame-container {
      height: calc(100vh - 68px);
      overflow: hidden;
    }
    .frame-iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
  </style>
</Layout>
