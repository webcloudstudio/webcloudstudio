          </div>

          <h3 class="card-title">Ed Barlows Sybase Stored Procedure</h3>
          <p class="card-desc">Widely Used Shareware Stored Procedure Library For SQL Server and Sybase Servers</p>

          <div class="tags">
            <span class={`tag ${getTagColorClass('Free')}`}>Free</span>
            <span class={`tag ${getTagColorClass('Stored Procedure')}`}>Stored Procedure</span>
            <span class={`tag ${getTagColorClass('Sql')}`}>Sql</span>
            <span class={`tag ${getTagColorClass('Server Administration')}`}>Server Administration</span>
          </div>

          
        </article>

        <!-- CARD: GEM -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">GEM</h3>
          <p class="card-desc">Generic Enterprise Manager is a full featured on-premise system management utility competitive with service now</p>

          <div class="tags">
            <span class={`tag ${getTagColorClass('Perl')}`}>Perl</span>
            <span class={`tag ${getTagColorClass('CGI')}`}>CGI</span>
            <span class={`tag ${getTagColorClass('Administration')}`}>Administration</span>
            <span class={`tag ${getTagColorClass('Monitoring')}`}>Monitoring</span>
            <span class={`tag ${getTagColorClass('Enterprise')}`}>Enterprise</span>
          </div>

          
        </article>

        <!-- CARD: Herpes Hearts -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Dating App &bull; Live</span>
              <a href="https://www.herpeshearts.com" target="_blank" rel="noopener" class="card-url">
                www.herpeshearts.com ↗
              </a>
            </div>
          </div>

          <h3 class="card-title">Herpes Hearts</h3>
          <p class="card-desc">A full-featured community dating platform built for the HSV+ community. Features OAuth-only authentication (Google), custom profiles, messaging, likes, blocking, and profile search.</p>

          <div class="tags">
            <span class={`tag ${getTagColorClass('Django')}`}>Django</span>
            <span class={`tag ${getTagColorClass('Python')}`}>Python</span>
            <span class={`tag ${getTagColorClass('PostgreSQL')}`}>PostgreSQL</span>
            <span class={`tag ${getTagColorClass('Docker')}`}>Docker</span>
            <span class={`tag ${getTagColorClass('Railway')}`}>Railway</span>
            <span class={`tag ${getTagColorClass('Bootstrap')}`}>Bootstrap</span>
            <span class={`tag ${getTagColorClass('OAuth')}`}>OAuth</span>
          </div>

          <div class="card-actions">
            <a href="https://www.herpeshearts.com" target="_blank" rel="noopener" class="btn-primary btn-sm">
              Live Site ↗
            </a>
          </div>
        </article>

        <!-- CARD: Process-Based Database Administration -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Book &bull; Published</span>
              <a href="https://www.amazon.com/Process-Based-Database-Administration-Management-ebook/dp/B073RRQBZC" target="_blank" rel="noopener" class="card-url">
                www.amazon.com ↗
              </a>
            </div>
          </div>

          <h3 class="card-title">Process-Based Database Administration</h3>
          <p class="card-desc">A practical guide to modern best practices for enterprise data and database systems management. Covers agile workflows, monitoring, security, disaster recovery, and database development at scale.</p>

          <div class="tags">
            <span class={`tag ${getTagColorClass('Database')}`}>Database</span>
            <span class={`tag ${getTagColorClass('PostgreSQL')}`}>PostgreSQL</span>
            <span class={`tag ${getTagColorClass('Agile')}`}>Agile</span>
            <span class={`tag ${getTagColorClass('Best Practices')}`}>Best Practices</span>
            <span class={`tag ${getTagColorClass('Enterprise')}`}>Enterprise</span>
          </div>

          <div class="card-actions">
            <a href="https://www.amazon.com/Process-Based-Database-Administration-Management-ebook/dp/B073RRQBZC" target="_blank" rel="noopener" class="btn-primary btn-sm">
              Live Site ↗
            </a>
          </div>
        </article>

        <!-- CARD: Senior.Tv -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">Senior.Tv</h3>
          <p class="card-desc"></p>

          <div class="tags">
            
          </div>

          
        </article>
        </div>
      </div>
    </div>
  </section>

  <script>
    const carouselTrack = document.querySelector('.carousel-track');
    const carouselPrev = document.getElementById('carousel-prev');
    const carouselNext = document.getElementById('carousel-next');
    const indicatorsContainer = document.getElementById('carousel-indicators');
    const cards = document.querySelectorAll('.carousel-track article');

    let currentSlide = 0;

    // Determine slides per view based on screen size
    function getSlidesPerView() {
      if (window.innerWidth < 769) return 1;
      if (window.innerWidth < 1201) return 2;
      return 3;
    }

    // Calculate total slides needed
    function getTotalSlides() {
      const slidesPerView = getSlidesPerView();
      return Math.ceil(cards.length / slidesPerView);
    }

    // Create indicator dots
    function createIndicators() {
      indicatorsContainer.innerHTML = '';
      const totalSlides = getTotalSlides();
      for (let i = 0; i < totalSlides; i++) {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot';
        if (i === 0) dot.classList.add('active');
        dot.addEventListener('click', () => goToSlide(i));
        indicatorsContainer.appendChild(dot);
      }
    }

    // Update carousel position with peek effect
    function updateCarousel() {
      const slidesPerView = getSlidesPerView();
      const offset = currentSlide * (100 / slidesPerView);
      carouselTrack.style.transform = `translateX(-${offset}%)`;

      // Update dots
      document.querySelectorAll('.carousel-dot').forEach((dot, i) => {
        dot.classList.toggle('active', i === currentSlide);
      });
    }

    // Navigate to specific slide
    function goToSlide(n) {
      const totalSlides = getTotalSlides();
      currentSlide = Math.max(0, Math.min(n, totalSlides - 1));
      updateCarousel();
    }

    // Next/Prev navigation with boundary checks
    function nextSlide() {
      const totalSlides = getTotalSlides();
      if (currentSlide < totalSlides - 1) {
        goToSlide(currentSlide + 1);
      }
    }

    function prevSlide() {
      if (currentSlide > 0) {
        goToSlide(currentSlide - 1);
      }
    }

    // Event listeners
    carouselNext.addEventListener('click', nextSlide);
    carouselPrev.addEventListener('click', prevSlide);

    // Handle window resize
    window.addEventListener('resize', () => {
      createIndicators();
      currentSlide = 0;
      updateCarousel();
    });

    // Initialize
    createIndicators();
    updateCarousel();
  </script>
</Layout>
