---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Papers — Ed Barlow">
  <section class="projects">
    <div class="section-inner">
      <div class="work-header">
        <h2>White Papers</h2>
      </div>
      <div class="card-grid">
        <a href="https://zenodo.org/records/21287574" target="_blank" rel="noopener" class="card card--featured">
          <div class="card-top">
            <div class="card-meta">
              <span class="card-type">White Paper</span>
              <h3 class="card-title">Improving Step Accuracy in Specification-Driven Development</h3>
            </div>
          </div>
          <p class="card-desc">White paper — Raising per-step accuracy in specification-driven development.</p>
          <div class="card-actions">
            <span class="btn-primary btn-sm">Read ↗</span>
          </div>
        </a>
        <a href="https://zenodo.org/records/21441315" target="_blank" rel="noopener" class="card card--featured">
          <div class="card-top">
            <div class="card-meta">
              <span class="card-type">White Paper</span>
              <h3 class="card-title">Managing Changes in Spec Driven Design</h3>
            </div>
          </div>
          <p class="card-desc">White paper - Best Practice for Updating Working Software in SDD</p>
          <div class="card-actions">
            <span class="btn-primary btn-sm">Read ↗</span>
          </div>
        </a>
        <a href={`${base}drydock/`} target="_blank" rel="noopener" class="card card--featured">
          <div class="card-top">
            <div class="card-meta">
              <span class="card-type">White Paper</span>
              <h3 class="card-title">Drydock Launch Deck</h3>
            </div>
          </div>
          <p class="card-desc">A full-page sales deck for Drydock, an innovative Agile SDD development process.</p>
          <div class="card-actions">
            <span class="btn-primary btn-sm">Read ↗</span>
          </div>
        </a>
        <a href={`${base}marina-aws/`} target="_blank" rel="noopener" class="card card--featured">
          <div class="card-top">
            <div class="card-meta">
              <span class="card-type">White Paper</span>
              <h3 class="card-title">The Marina Framework</h3>
            </div>
          </div>
          <p class="card-desc">My big SDD implementation — a trust and sharing architecture on AWS.</p>
          <div class="card-actions">
            <span class="btn-primary btn-sm">Read ↗</span>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
