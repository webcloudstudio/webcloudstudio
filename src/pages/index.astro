---
import Layout from '../layouts/Layout.astro';
import { getTagColorClass } from '../config/tags';
const base = import.meta.env.BASE_URL;
---
<Layout title="Web Cloud Studio — Ed Barlow">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow mono">&gt; cd ~/portfolio</p>
      <h1>
        <span class="name">Ed Barlow</span>
      </h1>
      <p class="hero-desc">
        Software engineer, database architect, and published author.
        Building thoughtful systems for complex problems.
      </p>
    </div>
    <div class="hero-grid"></div>
  </section>

  <!-- PROJECTS -->
  <section class="projects" id="projects">
    <div class="section-inner">
      <div class="carousel-header">
        <h3>Selected Work</h3>
        <div class="carousel-nav">
          <button class="carousel-button" id="carousel-prev" aria-label="Previous slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="carousel-indicators" id="carousel-indicators"></div>
          <button class="carousel-button" id="carousel-next" aria-label="Next slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>

      <div class="carousel-container">
        <div class="carousel-track">
        <!-- CARD: Enterprise Command Center -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">Enterprise Command Center</h3>
          <p class="card-desc">Claude Command Center - Process, Governance, and Reporting best standards for Claude Developers</p>

          <div class="tags">
            <span class={`tag ${getTagColorClass('Claude')}`}>Claude</span>
            <span class={`tag ${getTagColorClass('Administration')}`}>Administration</span>
            <span class={`tag ${getTagColorClass('Process')}`}>Process</span>
            <span class={`tag ${getTagColorClass('Best Practices')}`}>Best Practices</span>
          </div>

          
        </article>

        <!-- CARD: Conquer -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Free Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">Conquer</h3>
          <p class="card-desc">Conquer is a multi player C game published in the 80s and Early 90s</p>

          <div class="tags">
            <span class={`tag ${getTagColorClass('C++')}`}>C++</span>
            <span class={`tag ${getTagColorClass('Game')}`}>Game</span>
            <span class={`tag ${getTagColorClass('Mulit-Player')}`}>Mulit-Player</span>
          </div>

          
        </article>

        <!-- CARD: Ed Barlows Sybase Stored Procedure -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
