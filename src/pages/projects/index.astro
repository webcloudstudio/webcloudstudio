---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="My Projects — Ed Barlow">
  <section class="projects-page">
    <div class="section-inner">
      <div class="projects-header">
        <h1 class="page-title">My Projects</h1>
        
      </div>
      <div class="cards-grid">
        <!-- CARD: Ed Barlows Stored Procedure Library -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/EdBarlowsStoredProcs.webp" alt="Ed Barlows Stored Procedure Library" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--ops">Sybase</span>
            <span class="tag tag--ops">Sql Server</span>
            </div>

            <h3 class="card-title">Ed Barlows Stored Procedure Library</h3>

            <p class="card-desc">Widely Used Shareware Stored Procedure Library For SQL Server and Sybase Servers</p>
          </div>

          <div class="card-actions">
            <a href="/webcloudstudio/project-docs/EdBarlowsStoredProcs/index.html" target="_blank" rel="noopener" class="card-link-btn">Documentation ↗</a>
            <a href="https://webcloudstudio.github.io/webcloudstudio/project-docs/EdBarlowsStoredProcs/index.html" target="_blank" rel="noopener" class="card-link-btn">Details ↗</a>
          </div>
        </article>

        <!-- CARD: GAME — Project Framework -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/GAME.webp" alt="GAME — Project Framework" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--py">Python</span>
            <span class="tag tag--neutral">Project Framework</span>
            </div>

            <h3 class="card-title">GAME — Project Framework</h3>

            <p class="card-desc">Full Featured Operations Framework For Projects. Based on GEM Enterprise Manager Rules and Standards. I use it for ALL my projects (writing, finance, code).</p>
          </div>

          <div class="card-actions">
            <a href="/webcloudstudio/project-docs/GAME/index.html" target="_blank" rel="noopener" class="card-link-btn">Documentation ↗</a>
            
          </div>
        </article>

        <!-- CARD: Herpes Hearts -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/HerpesHearts.webp" alt="Herpes Hearts" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--py">Django</span>
            <span class="tag tag--ops">Docker</span>
            <span class="tag tag--ops">Railway</span>
            </div>

            <h3 class="card-title">Herpes Hearts</h3>

            <p class="card-desc">Completely Free Django dating platform built for the HSV+ community.</p>
          </div>

          <div class="card-actions">
            
            <a href="https://www.herpeshearts.com" target="_blank" rel="noopener" class="card-link-btn">Details ↗</a>
          </div>
        </article>

        <!-- CARD: Process-Based Database Administration -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/ProcessBasedDataEngineering.webp" alt="Process-Based Database Administration" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--py">Best Practices</span>
            <span class="tag tag--neutral">Data Engineering</span>
            </div>

            <h3 class="card-title">Process-Based Database Administration</h3>

            <p class="card-desc">A practical guide to modern best practices for enterprise data and database systems management. Covers agile workflows, monitoring, security, disaster recovery, and database development at scale.</p>
          </div>

          <div class="card-actions">
            
            <a href="https://www.amazon.com/Process-Based-Database-Administration-Management-ebook/dp/B073RRQBZC" target="_blank" rel="noopener" class="card-link-btn">Details ↗</a>
          </div>
        </article>

        <!-- CARD: Specifications -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/prototyper.webp" alt="Specifications" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              
            </div>

            <h3 class="card-title">Specifications</h3>

            <p class="card-desc">Project Prototyper And Business Rules Integration - One Shot framework with integration of business standards. Pairs with GAME command, control, and observability framework.</p>
          </div>

          <div class="card-actions">
            <a href="/webcloudstudio/project-docs/Specifications/index.html" target="_blank" rel="noopener" class="card-link-btn">Documentation ↗</a>
            
          </div>
        </article>

        <!-- CARD: conquer_2026 -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/conquer_2026.webp" alt="conquer_2026" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--neutral">Strategy Game</span>
            <span class="tag tag--neutral">Multi-Player</span>
            <span class="tag tag--fe">React</span>
            <span class="tag-break"></span>
            <span class="tag tag--neutral">FastAPI</span>
            </div>

            <h3 class="card-title">conquer_2026</h3>

            <p class="card-desc">Modern port of the classic 1990s multi-player hex-map strategy game</p>
          </div>

          <div class="card-actions">
            <a href="/webcloudstudio/project-docs/conquer_2026/index.html" target="_blank" rel="noopener" class="card-link-btn">Documentation ↗</a>
            
          </div>
        </article>

        <!-- CARD: GEM Enterprise Manager -->
        <article class="card">
          <div class="card-image-wrapper">
            <img src="/webcloudstudio/images/gem.webp" alt="GEM Enterprise Manager" class="card-image"/>
          </div>

          <div class="card-content">
            <div class="tags">
              <span class="tag tag--db">Perl</span>
            <span class="tag tag--neutral">CMDB</span>
            <span class="tag tag--neutral">Opertions</span>
            <span class="tag-break"></span>
            <span class="tag tag--db">Monitoring</span>
            </div>

            <h3 class="card-title">GEM Enterprise Manager</h3>

            <p class="card-desc">Enterprise Managemer utilized to manage on-prem production databases (~200) and hosts (~10000) at top 5 hedge funds and banks circa 2012. Configuration Management, Alerting & Monitoring, Operations, Batch Cycle.  Service Now Equivalent.</p>
          </div>

          <div class="card-actions">
            <a href="/webcloudstudio/project-docs/gem/index.html" target="_blank" rel="noopener" class="card-link-btn">Documentation ↗</a>
            
          </div>
        </article>
      </div>
    </div>
  </section>

  <style>
    .projects-page { padding: 3rem 0; }

    .projects-header { text-align: center; margin-bottom: 2.5rem; }

    .page-title {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 800;
      margin: 0 0 0.4rem;
    }

    .page-subtitle {
      color: var(--muted);
      font-size: 1rem;
      margin: 0;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      column-gap: 1.5rem;
      row-gap: 1.5rem;
    }

    @media (max-width: 1280px) {
      .cards-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 1024px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .cards-grid { grid-template-columns: 1fr; }
    }

    /* Override global Layout.astro card padding/gap — must be explicit */
    .card {
      padding: 0 !important;
      gap: 0 !important;
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
    }

    .card:hover {
      border-color: #4f9cf950;
      box-shadow: 0 6px 24px #4f9cf910;
      transform: translateY(-2px);
    }

    /* Image: full bleed, no margin */
    .card-image-wrapper {
      width: 100%;
      height: 140px;
      margin: 0;
      padding: 0;
      background: var(--surface2);
      overflow: hidden;
      flex-shrink: 0;
      display: block;
    }

    .card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      margin: 0;
      padding: 0;
      transition: transform 0.3s ease;
    }

    .card:hover .card-image { transform: scale(1.03); }

    .card-image-placeholder {
      height: 140px;
      background: linear-gradient(135deg, var(--surface) 0%, var(--surface2) 100%);
    }

    /* Content */
    .card-content {
      flex: 1;
      padding: 0.7rem 1rem 0.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    /* Tags: first 3 on row 1, remainder on row 2 */
    .tags {
      display: flex !important;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 0.2rem;
    }

    .tag {
      font-size: 0.7rem;
      font-family: 'Fira Code', monospace;
      padding: 0.18rem 0.45rem;
      border-radius: 4px;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }

    /* Zero-size flex break injected after 3rd tag in Python */
    .tag-break {
      flex-basis: 100%;
      width: 0;
      height: 0;
    }

    /* Title: tight spacing above and below */
    .card-title {
      margin: 0.15rem 0 0.1rem;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.25;
    }

    .card-desc {
      margin: 0;
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.55;
    }

    /* Actions: docs + github buttons side by side */
    .card-actions {
      padding: 0.4rem 1rem 0.6rem;
      margin-top: auto !important;
      display: flex;
      flex-direction: row;
      gap: 0.4rem;
    }

    .card-link-btn {
      display: block;
      text-align: center;
      text-decoration: none;
      box-sizing: border-box;
      background: none;
      border: 1px solid var(--accent);
      color: var(--accent);
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s, color 0.2s;
      flex: 1;
    }

    .card-link-btn:hover {
      background: var(--accent);
      color: #080810;
    }

  </style>
</Layout>
