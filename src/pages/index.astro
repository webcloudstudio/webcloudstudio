---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Web Cloud Studio — Ed Barlow">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow mono">&gt; cd ~/portfolio</p>
      <h1>
        <span class="name">Ed Barlow</span>
      </h1>
      <p class="hero-desc">
        Software engineer, database architect, and published author.
        Building thoughtful systems for complex problems.
      </p>
    </div>
    <div class="hero-grid"></div>
  </section>

  <!-- PROJECTS -->
  <section class="projects" id="projects">
    <div class="section-inner">
      <div class="work-header">
        <h2>Selected Work</h2>
        <div class="work-controls">
          <button id="scroll-prev" class="scroll-btn" aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button id="scroll-next" class="scroll-btn" aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>

      <div class="cards-scroll-container">
        <div class="cards-scroll-track">
        <!-- CARD: Enterprise Command Center -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">Enterprise Command Center</h3>
          <p class="card-desc">Claude Command Center
Operations :  Monitoring: Notifications & Heartbeats
Scheduler: Jobs (instances), Daemons/Batches, Schedules
Mandated Standards and Security
Project MetaData
                        Git, Unit Tests, Versioning
                Standard Command & Control Layer
                Integrated Configuration
        Github Home Page Publishing
        User Workflow
                Proposal -> Defined -> Submit/Develop -> Test -> Release
                Project/Epic/Feature Tickets
        Hooks
                New Project
                Alerts/Popups - Im Done, Compact Me, Usage Warning</p>

          <div class="tags">
            <span class="tag tag--py">Claude</span>
            <span class="tag tag--fe">Administration</span>
            <span class="tag tag--db">Process</span>
            <span class="tag tag--py">Best Practices</span>
          </div>

          
        </article>

        <!-- CARD: Conquer -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Free Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">Conquer</h3>
          <p class="card-desc">Conquer is a multi player C game published in the 80s and Early 90s</p>

          <div class="tags">
            <span class="tag tag--db">C++</span>
            <span class="tag tag--sec">Game</span>
            <span class="tag tag--sec">Mulit-Player</span>
          </div>

          
        </article>

        <!-- CARD: Ed Barlows Sybase Stored Procedure -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">Ed Barlows Sybase Stored Procedure</h3>
          <p class="card-desc">Widely Used Shareware Stored Procedure Library For SQL Server and Sybase Servers</p>

          <div class="tags">
            <span class="tag tag--db">Free</span>
            <span class="tag tag--ops">Stored Procedure</span>
            <span class="tag tag--sec">Sql</span>
            <span class="tag tag--sec">Server Administration</span>
          </div>

          
        </article>

        <!-- CARD: GEM -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Software &bull; In Progress</span>
              
            </div>
          </div>

          <h3 class="card-title">GEM</h3>
          <p class="card-desc">Generic Enterprise Manager is a full featured on-premise system management utility competitive with service now</p>

          <div class="tags">
            <span class="tag tag--db">Perl</span>
            <span class="tag tag--neutral">CGI</span>
            <span class="tag tag--fe">Administration</span>
            <span class="tag tag--db">Monitoring</span>
            <span class="tag tag--db">Enterprise</span>
          </div>

          
        </article>

        <!-- CARD: Herpes Hearts -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Dating App &bull; Live</span>
              <a href="https://www.herpeshearts.com" target="_blank" rel="noopener" class="card-url">
                www.herpeshearts.com ↗
              </a>
            </div>
          </div>

          <h3 class="card-title">Herpes Hearts</h3>
          <p class="card-desc">A full-featured community dating platform built for the HSV+ community. Features OAuth-only authentication (Google), custom profiles, messaging, likes, blocking, and profile search.</p>

          <div class="tags">
            <span class="tag tag--py">Django</span>
            <span class="tag tag--py">Python</span>
            <span class="tag tag--db">PostgreSQL</span>
            <span class="tag tag--ops">Docker</span>
            <span class="tag tag--ops">Railway</span>
            <span class="tag tag--fe">Bootstrap</span>
            <span class="tag tag--sec">OAuth</span>
          </div>

          <div class="card-actions">
            <a href="https://www.herpeshearts.com" target="_blank" rel="noopener" class="btn-primary btn-sm">
              Live Site ↗
            </a>
          </div>
        </article>

        <!-- CARD: Process-Based Database Administration -->
        <article class="card card--featured">
          <div class="card-top">
            <div class="card-icon " aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
            <div class="card-meta">
              <span class="card-type">Book &bull; Published</span>
              <a href="https://www.amazon.com/Process-Based-Database-Administration-Management-ebook/dp/B073RRQBZC" target="_blank" rel="noopener" class="card-url">
                www.amazon.com ↗
              </a>
            </div>
          </div>

          <h3 class="card-title">Process-Based Database Administration</h3>
          <p class="card-desc">A practical guide to modern best practices for enterprise data and database systems management. Covers agile workflows, monitoring, security, disaster recovery, and database development at scale.</p>

          <div class="tags">
            <span class="tag tag--db">Database</span>
            <span class="tag tag--db">PostgreSQL</span>
            <span class="tag tag--sec">Agile</span>
            <span class="tag tag--py">Best Practices</span>
            <span class="tag tag--db">Enterprise</span>
          </div>

          <div class="card-actions">
            <a href="https://www.amazon.com/Process-Based-Database-Administration-Management-ebook/dp/B073RRQBZC" target="_blank" rel="noopener" class="btn-primary btn-sm">
              Live Site ↗
            </a>
          </div>
        </article>
        </div>
      </div>
    </div>
  </section>

  <script>
    const scrollTrack = document.querySelector('.cards-scroll-track');
    const prevBtn = document.getElementById('scroll-prev');
    const nextBtn = document.getElementById('scroll-next');

    let scrollOffset = 0;

    // Get how many cards fit per view
    function getCardsPerView() {
      const width = window.innerWidth;
      if (width < 769) return 1;
      if (width < 1201) return 2;
      return 3;
    }

    // Scroll by one card width
    function scroll(direction) {
      const cardsPerView = getCardsPerView();
      const cardCount = scrollTrack.querySelectorAll('article').length;
      const maxScroll = Math.max(0, cardCount - cardsPerView);

      if (direction === 'next') {
        scrollOffset = Math.min(scrollOffset + 1, maxScroll);
      } else {
        scrollOffset = Math.max(scrollOffset - 1, 0);
      }

      updateScroll();
    }

    // Apply scroll transform
    function updateScroll() {
      const cardsPerView = getCardsPerView();
      const offset = scrollOffset * (100 / cardsPerView);
      scrollTrack.style.transform = `translateX(-${offset}%)`;

      // Update button states
      const cardCount = scrollTrack.querySelectorAll('article').length;
      const maxScroll = Math.max(0, cardCount - cardsPerView);
      prevBtn.disabled = scrollOffset === 0;
      nextBtn.disabled = scrollOffset === maxScroll;
    }

    // Event listeners
    prevBtn.addEventListener('click', () => scroll('prev'));
    nextBtn.addEventListener('click', () => scroll('next'));

    // Handle window resize
    window.addEventListener('resize', () => {
      scrollOffset = 0;
      updateScroll();
    });

    // Initialize
    updateScroll();
  </script>
</Layout>
