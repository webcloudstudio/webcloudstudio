---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Web Cloud Studio — Software Portfolio' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg:        #080810;
        --surface:   #0e0e1a;
        --surface2:  #13132080;
        --border:    #1e1e35;
        --accent:    #4f9cf9;
        --accent2:   #a78bfa;
        --text:      #e2e8f0;
        --muted:     #64748b;
        --danger:    #f87171;
        --green:     #4ade80;
        --orange:    #fb923c;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      code, .mono {
        font-family: 'Fira Code', 'Courier New', monospace;
        font-size: 0.88em;
      }

      /* ── NAV ── */
      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #08081099;
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      nav {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo {
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.1em;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .logo:hover { text-decoration: none; }
      .logo-dot { color: var(--accent); }

      .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
      }
      .nav-links a {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
      }
      .nav-links a:hover { color: var(--text); text-decoration: none; }

      /* contact card */
      .contact-trigger { position: relative; }

      .nav-contact-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 500;
        font-family: inherit;
        padding: 0;
        transition: color 0.2s;
      }
      .nav-contact-btn:hover { color: var(--text); }

      .contact-card {
        position: absolute;
        top: calc(100% + 14px);
        right: 0;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        min-width: 230px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-4px);
        transition: opacity 0.18s, visibility 0.18s, transform 0.18s;
        pointer-events: none;
        z-index: 200;
        box-shadow: 0 8px 32px #00000066;
      }

      /* arrow */
      .contact-card::before {
        content: '';
        position: absolute;
        top: -6px;
        right: 16px;
        width: 10px;
        height: 10px;
        background: var(--surface);
        border-left: 1px solid var(--border);
        border-top: 1px solid var(--border);
        transform: rotate(45deg);
      }

      .contact-trigger:hover .contact-card,
      .contact-trigger:focus-within .contact-card {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        pointer-events: auto;
      }

      .contact-name {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
      }

      .contact-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.83rem;
        color: var(--muted);
        padding: 0.35rem 0;
        border-radius: 4px;
        transition: color 0.15s;
        text-decoration: none;
      }
      .contact-item:hover { color: var(--accent); text-decoration: none; }
      .contact-item svg { flex-shrink: 0; color: var(--accent); }

      /* ── MAIN ── */
      main { flex: 1; }

      section {
        padding: 3rem 1.5rem;
      }

      .section-inner {
        max-width: 1100px;
        margin: 0 auto;
      }

      /* ── HERO ── */
      .hero {
        position: relative;
        min-height: auto;
        padding: 3rem 0 2rem;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
      }

      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(79,156,249,0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(79,156,249,0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        pointer-events: none;
      }

      .hero-grid::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 0%, #08081066 100%);
        pointer-events: none;
      }

      .hero-inner {
        position: relative;
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        gap: 3rem;
      }

      .hero-content {
        flex: 1;
      }

      .hero-logo {
        flex: 0 0 auto;
        width: 200px;
        height: 200px;
        border-radius: 12px;
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .hero-logo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      @media (max-width: 768px) {
        .hero-inner {
          flex-direction: column;
          gap: 2rem;
        }

        .hero-logo {
          width: 160px;
          height: 160px;
        }
      }

      .hero-eyebrow {
        color: var(--muted);
        font-size: 0.85rem;
        opacity: 0.8;
        margin-bottom: 1rem;
        display: none;
      }

      .hero h1 {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin: 1rem 0;
      }

      .name { color: var(--text); }
      .rule { width: 2px; height: 2.5rem; background: var(--border); flex-shrink: 0; }
      .role { color: var(--accent); }

      .hero-desc {
        font-size: 1rem;
        color: var(--muted);
        max-width: 600px;
        margin: 1.5rem 0;
        line-height: 1.7;
      }

      .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

      /* ── BUTTONS ── */
      .btn-primary {
        display: inline-block;
        padding: 0.65rem 1.5rem;
        background: var(--accent);
        color: #080810;
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 6px;
        transition: opacity 0.2s, transform 0.15s;
        text-decoration: none;
      }
      .btn-primary:hover {
        opacity: 0.88;
        text-decoration: none;
        transform: translateY(-1px);
      }

      .btn-ghost {
        display: inline-block;
        padding: 0.65rem 1.5rem;
        border: 1px solid var(--border);
        color: var(--text);
        font-weight: 500;
        font-size: 0.9rem;
        border-radius: 6px;
        transition: border-color 0.2s, background 0.2s;
        text-decoration: none;
      }
      .btn-ghost:hover {
        border-color: var(--accent);
        background: #4f9cf910;
        text-decoration: none;
      }

      .btn-sm { padding: 0.5rem 1.1rem; font-size: 0.85rem; }

      /* ── PROJECTS SECTION ── */
      .projects {
        padding: 2rem 0;
      }

      .section-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .section-header {
        margin-bottom: 3rem;
      }

      .work-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        margin-bottom: 2.5rem;
      }

      .work-header h2 {
        font-size: clamp(1.3rem, 3vw, 1.8rem);
        font-weight: 700;
        letter-spacing: -0.01em;
        margin: 0;
      }

      .work-controls {
        display: flex;
        gap: 0.75rem;
        flex-shrink: 0;
      }

      .scroll-btn {
        background: none;
        border: 1px solid var(--border);
        color: var(--text);
        width: 40px;
        height: 40px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
      }

      .scroll-btn:hover:not(:disabled) {
        border-color: var(--accent);
        color: var(--accent);
        background: #4f9cf908;
      }

      .scroll-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
      }

      .section-tag {
        color: var(--accent);
        font-size: 0.85rem;
        opacity: 0.7;
        display: block;
        margin-bottom: 0.5rem;
      }

      .section-header h2 {
        font-size: clamp(1.8rem, 4vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
      }

      .section-sub {
        color: var(--muted);
        font-size: 1rem;
      }

      /* ── CARDS SCROLL ── */
      .cards-scroll-container {
        position: relative;
        overflow: hidden;
      }

      .cards-scroll-track {
        display: flex;
        gap: 1.5rem;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      /* Mobile: 1 card per view */
      .cards-scroll-track article {
        flex: 0 0 100%;
        min-width: 100%;
      }

      /* Tablet: 2 cards per view */
      @media (min-width: 769px) {
        .cards-scroll-track article {
          flex: 0 0 calc(50% - 0.75rem);
          min-width: calc(50% - 0.75rem);
        }
      }

      /* Desktop: 3 cards per view */
      @media (min-width: 1201px) {
        .cards-scroll-track article {
          flex: 0 0 calc(33.333% - 1rem);
          min-width: calc(33.333% - 1rem);
        }
      }

      /* ── CARDS ── */
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
      }

      .card:hover {
        border-color: #4f9cf940;
        box-shadow: 0 0 40px #4f9cf910;
        transform: translateY(-3px);
      }

      .card--featured {
        border-color: #a78bfa30;
      }

      .card--featured:hover {
        border-color: #a78bfa60;
        box-shadow: 0 0 40px #a78bfa12;
      }

      .card-top {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }

      .card-icon {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: linear-gradient(135deg, #a78bfa22, #a78bfa44);
        border: 1px solid #a78bfa30;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent2);
      }

      .card-icon--book {
        background: linear-gradient(135deg, #4f9cf922, #4f9cf944);
        border-color: #4f9cf930;
        color: var(--accent);
      }

      .card-meta {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }

      .card-type {
        font-size: 0.75rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 500;
      }

      .card-url {
        font-size: 0.82rem;
        font-family: 'Fira Code', monospace;
        color: var(--accent);
        opacity: 0.8;
        transition: opacity 0.2s;
        text-decoration: none;
      }
      .card-url:hover { opacity: 1; text-decoration: none; }

      .card-title {
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1.3;
        color: var(--text);
      }

      .card-desc {
        font-size: 0.93rem;
        color: var(--muted);
        line-height: 1.7;
        flex: 1;
      }

      /* ── TAGS ── */
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .tag {
        font-size: 0.72rem;
        font-family: 'Fira Code', monospace;
        padding: 0.2rem 0.55rem;
        border-radius: 4px;
        font-weight: 500;
        letter-spacing: 0.02em;
      }

      .tag--green   { background: #22c55e18; color: #4ade80; border: 1px solid #22c55e30; }
      .tag--orange  { background: #fb923c18; color: #fb923c; border: 1px solid #fb923c30; }
      .tag--blue    { background: #4f9cf918; color: #4f9cf9; border: 1px solid #4f9cf930; }
      .tag--purple  { background: #a78bfa18; color: #a78bfa; border: 1px solid #a78bfa30; }
      .tag--red     { background: #f8717118; color: #f87171; border: 1px solid #f8717130; }
      .tag--slate   { background: #64748b18; color: #94a3b8; border: 1px solid #64748b30; }

      /* Legacy aliases for backwards compatibility */
      .tag--py      { background: #22c55e18; color: #4ade80; border: 1px solid #22c55e30; }
      .tag--db      { background: #fb923c18; color: #fb923c; border: 1px solid #fb923c30; }
      .tag--ops     { background: #4f9cf918; color: #4f9cf9; border: 1px solid #4f9cf930; }
      .tag--fe      { background: #a78bfa18; color: #a78bfa; border: 1px solid #a78bfa30; }
      .tag--sec     { background: #f8717118; color: #f87171; border: 1px solid #f8717130; }
      .tag--neutral { background: #64748b18; color: #94a3b8; border: 1px solid #64748b30; }

      /* ── CARD ACTIONS ── */
      .card-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: auto;
        padding-top: 0.25rem;
      }

      /* ── FOOTER ── */
      footer {
        border-top: 1px solid var(--border);
        padding: 2rem 1.5rem;
        text-align: center;
        color: var(--muted);
        font-size: 0.82rem;
        letter-spacing: 0.05em;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href={base} class="logo">Web Cloud Studio</a>
        <div class="nav-links">
          <a href={base}>Home</a>
          <a href={`${base}#projects`}>Projects</a>
          <a href={`${base}/resume/`}>About Me</a>
          <div class="contact-trigger">
            <button class="nav-contact-btn">Contact</button>
            <div class="contact-card" role="tooltip">
              <p class="contact-name">Ed Barlow</p>
              <a href="mailto:edward.m.barlow@gmail.com" class="contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                edward.m.barlow@gmail.com
              </a>
              <a href="tel:+19148374798" class="contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.5 16.4z"/></svg>
                (914) 837-4798
              </a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      &copy; {new Date().getFullYear()} Web Cloud Studio &mdash; Ed Barlow
    </footer>
  </body>
</html>
