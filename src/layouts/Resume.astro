---
import Layout from './Layout.astro';
---

<Layout title="About — Ed Barlow">
  <style is:global>
    .resume-container {
      max-width: 700px;
      margin: 0 auto;
      padding: 4rem 2rem;
      line-height: 1.8;
      font-size: 1.05rem;
    }

    .resume-container h1 {
      font-size: 2rem;
      font-weight: 400;
      margin: 0 0 0.5rem 0;
      color: var(--text);
    }

    .resume-container h2 {
      font-size: 1rem;
      font-weight: 400;
      color: var(--muted);
      margin: 0 0 2rem 0;
      text-transform: none;
    }

    .resume-container p {
      color: var(--text);
      margin: 1.5rem 0;
      font-weight: 400;
    }

    .resume-container img {
      display: block;
    }

    .resume-container a {
      color: var(--accent);
      text-decoration: none;
    }

    .resume-container a:hover {
      text-decoration: underline;
    }

    @media print {
      body { background: white; color: black; }
      .resume-container { padding: 0; }
      .resume-container h1 { color: black; }
      .resume-container h2 { color: #666; }
      .resume-container p { color: black; }
      .resume-container a { color: #0066cc; }
    }
  </style>

  <div class="resume-container">
    <slot />
  </div>
</Layout>
